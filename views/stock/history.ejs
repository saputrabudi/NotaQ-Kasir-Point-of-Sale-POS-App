<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0"><i class="bi bi-clock-history me-2"></i>Riwayat Penyesuaian Stok</h4>
  <a href="/stock" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i>Kembali
  </a>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Tanggal</th>
            <th>Produk</th>
            <th>Barcode</th>
            <th>User</th>
            <th class="text-center">Sebelum</th>
            <th class="text-center">Perubahan</th>
            <th class="text-center">Sesudah</th>
            <th>Alasan</th>
          </tr>
        </thead>
        <tbody>
          <% if (adjustments.length === 0) { %>
            <tr>
              <td colspan="8" class="text-center text-muted py-4">Belum ada riwayat penyesuaian</td>
            </tr>
          <% } else { %>
            <% adjustments.forEach(adj => { %>
              <tr>
                <td><%= new Date(adj.created_at).toLocaleString('id-ID') %></td>
                <td><%= adj.product_name %></td>
                <td><code><%= adj.barcode || '-' %></code></td>
                <td><%= adj.user_name %></td>
                <td class="text-center"><%= adj.qty_before %></td>
                <td class="text-center">
                  <span class="badge bg-<%= adj.adjustment > 0 ? 'success' : 'danger' %>">
                    <%= adj.adjustment > 0 ? '+' : '' %><%= adj.adjustment %>
                  </span>
                </td>
                <td class="text-center"><%= adj.qty_after %></td>
                <td><%= adj.reason || '-' %></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  
  <% if (totalPages > 1) { %>
    <div class="card-footer bg-white">
      <nav>
        <ul class="pagination pagination-sm mb-0 justify-content-center">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
              <a class="page-link" href="/stock/history?page=<%= i %>"><%= i %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    </div>
  <% } %>
</div>
