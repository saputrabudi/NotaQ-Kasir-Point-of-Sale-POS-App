<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0"><i class="bi bi-receipt me-2"></i>Riwayat Penjualan</h4>
</div>

<!-- Filter -->
<div class="card mb-4">
  <div class="card-body">
    <form action="/sales/history" method="GET" class="row g-2">
      <div class="col-md-4">
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-search"></i></span>
          <input type="text" class="form-control" name="search" placeholder="Cari invoice..." value="<%= search %>">
        </div>
      </div>
      <div class="col-md-3">
        <input type="date" class="form-control" name="date_from" value="<%= dateFrom %>" placeholder="Dari tanggal">
      </div>
      <div class="col-md-3">
        <input type="date" class="form-control" name="date_to" value="<%= dateTo %>" placeholder="Sampai tanggal">
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Filter</button>
      </div>
    </form>
  </div>
</div>

<!-- Sales Table -->
<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Invoice</th>
            <th>Tanggal</th>
            <th>Kasir</th>
            <th class="text-end">Total</th>
            <th class="text-center">Metode</th>
            <th class="text-center">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (sales.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center text-muted py-4">Tidak ada data penjualan</td>
            </tr>
          <% } else { %>
            <% sales.forEach(sale => { %>
              <tr>
                <td>
                  <a href="/sales/<%= sale.id %>" class="text-decoration-none fw-bold">
                    <%= sale.invoice_no %>
                  </a>
                </td>
                <td><%= new Date(sale.created_at).toLocaleString('id-ID') %></td>
                <td><%= sale.cashier_name %></td>
                <td class="text-end">Rp <%= sale.total.toLocaleString('id-ID') %></td>
                <td class="text-center">
                  <% if (sale.payment_method === 'qris') { %>
                    <span class="badge bg-primary"><i class="fa-solid fa-qrcode me-1"></i>QRIS</span>
                  <% } else { %>
                    <span class="badge bg-success"><i class="bi bi-cash me-1"></i>Tunai</span>
                  <% } %>
                </td>
                <td class="text-center">
                  <a href="/sales/<%= sale.id %>" class="btn btn-sm btn-outline-primary" target="_blank">
                    <i class="bi bi-printer"></i>
                  </a>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  
  <% if (totalPages > 1) { %>
    <div class="card-footer bg-white">
      <nav>
        <ul class="pagination pagination-sm mb-0 justify-content-center">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
              <a class="page-link" href="/sales/history?page=<%= i %>&search=<%= search %>&date_from=<%= dateFrom %>&date_to=<%= dateTo %>">
                <%= i %>
              </a>
            </li>
          <% } %>
        </ul>
      </nav>
    </div>
  <% } %>
</div>
