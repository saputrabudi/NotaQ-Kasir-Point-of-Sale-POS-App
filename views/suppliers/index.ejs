<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0"><i class="bi bi-truck me-2"></i>Manajemen Supplier</h4>
  <a href="/suppliers/create" class="btn btn-primary">
    <i class="bi bi-plus-lg me-1"></i>Tambah Supplier
  </a>
</div>

<div class="row">
  <div class="col-lg-10">
    <div class="card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Nama Supplier</th>
                <th>Telepon</th>
                <th>Alamat</th>
                <th class="text-center">Jumlah PO</th>
                <th class="text-center">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% if (suppliers.length === 0) { %>
                <tr>
                  <td colspan="5" class="text-center text-muted py-4">Belum ada supplier</td>
                </tr>
              <% } else { %>
                <% suppliers.forEach(supplier => { %>
                  <tr>
                    <td>
                      <i class="bi bi-building me-2 text-primary"></i>
                      <strong><%= supplier.name %></strong>
                    </td>
                    <td><%= supplier.phone || '-' %></td>
                    <td><%= supplier.address || '-' %></td>
                    <td class="text-center">
                      <span class="badge bg-secondary"><%= supplier.po_count %> PO</span>
                    </td>
                    <td class="text-center">
                      <div class="btn-group btn-group-sm">
                        <a href="/suppliers/<%= supplier.id %>/edit" class="btn btn-outline-primary">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <button type="button" class="btn btn-outline-danger" 
                          onclick="confirmDelete(<%= supplier.id %>, '<%= supplier.name %>')">
                          <i class="bi bi-trash"></i>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Delete Form -->
<form id="deleteForm" method="POST" style="display: none;">
  <input type="hidden" name="_method" value="DELETE">
</form>

<script>
function confirmDelete(id, name) {
  Swal.fire({
    title: 'Hapus Supplier?',
    text: `Apakah Anda yakin ingin menghapus "${name}"?`,
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#dc3545',
    cancelButtonColor: '#6c757d',
    confirmButtonText: 'Ya, Hapus!',
    cancelButtonText: 'Batal'
  }).then((result) => {
    if (result.isConfirmed) {
      const form = document.getElementById('deleteForm');
      form.action = `/suppliers/${id}?_method=DELETE`;
      form.submit();
    }
  });
}
</script>
