<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Detail PO: <%= order.po_number %></h4>
  <div>
    <a href="/purchase-orders/<%= order.id %>/print" class="btn btn-outline-secondary" target="_blank">
      <i class="bi bi-printer me-1"></i>Print
    </a>
    <a href="/purchase-orders" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i>Kembali
    </a>
  </div>
</div>

<div class="row">
  <div class="col-lg-8">
    <!-- Items -->
    <div class="card mb-4">
      <div class="card-header bg-white">
        <h6 class="mb-0">Item PO</h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Produk</th>
                <th>Barcode</th>
                <th class="text-center">Qty</th>
                <th class="text-end">Harga</th>
                <th class="text-end">Subtotal</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(item => { %>
                <tr>
                  <td><%= item.product_name %></td>
                  <td><code><%= item.barcode || '-' %></code></td>
                  <td class="text-center"><%= item.qty %></td>
                  <td class="text-end">Rp <%= item.price.toLocaleString('id-ID') %></td>
                  <td class="text-end">Rp <%= item.subtotal.toLocaleString('id-ID') %></td>
                </tr>
              <% }) %>
            </tbody>
            <tfoot class="table-light">
              <tr>
                <th colspan="4" class="text-end">Total:</th>
                <th class="text-end">Rp <%= order.total.toLocaleString('id-ID') %></th>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </div>
  </div>
  
  <div class="col-lg-4">
    <!-- PO Info -->
    <div class="card mb-4">
      <div class="card-header bg-white">
        <h6 class="mb-0">Informasi PO</h6>
      </div>
      <div class="card-body">
        <table class="table table-borderless table-sm mb-0">
          <tr>
            <td>No. PO</td>
            <td><strong><%= order.po_number %></strong></td>
          </tr>
          <tr>
            <td>Tanggal</td>
            <td><%= new Date(order.created_at).toLocaleDateString('id-ID') %></td>
          </tr>
          <tr>
            <td>Supplier</td>
            <td><%= order.supplier_name || '-' %></td>
          </tr>
          <tr>
            <td>Telepon</td>
            <td><%= order.supplier_phone || '-' %></td>
          </tr>
          <tr>
            <td>Dibuat Oleh</td>
            <td><%= order.user_name %></td>
          </tr>
          <tr>
            <td>Status</td>
            <td>
              <% if (order.status === 'draft') { %>
                <span class="badge bg-secondary">Draft</span>
              <% } else if (order.status === 'ordered') { %>
                <span class="badge bg-primary">Ordered</span>
              <% } else if (order.status === 'received') { %>
                <span class="badge bg-success">Received</span>
              <% } else { %>
                <span class="badge bg-danger">Cancelled</span>
              <% } %>
            </td>
          </tr>
          <% if (order.received_date) { %>
            <tr>
              <td>Diterima</td>
              <td><%= new Date(order.received_date).toLocaleDateString('id-ID') %></td>
            </tr>
          <% } %>
          <% if (order.notes) { %>
            <tr>
              <td>Catatan</td>
              <td><%= order.notes %></td>
            </tr>
          <% } %>
        </table>
      </div>
    </div>
    
    <!-- Actions -->
    <% if (order.status === 'draft' || order.status === 'ordered') { %>
      <div class="card">
        <div class="card-header bg-white">
          <h6 class="mb-0">Aksi</h6>
        </div>
        <div class="card-body">
          <% if (order.status === 'draft') { %>
            <form action="/purchase-orders/<%= order.id %>/status" method="POST" class="mb-2">
              <input type="hidden" name="status" value="ordered">
              <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-send me-1"></i>Kirim Order
              </button>
            </form>
            <form action="/purchase-orders/<%= order.id %>?_method=DELETE" method="POST">
              <button type="submit" class="btn btn-outline-danger w-100" onclick="return confirm('Hapus PO ini?')">
                <i class="bi bi-trash me-1"></i>Hapus PO
              </button>
            </form>
          <% } else if (order.status === 'ordered') { %>
            <form action="/purchase-orders/<%= order.id %>/status" method="POST" class="mb-2">
              <input type="hidden" name="status" value="received">
              <button type="submit" class="btn btn-success w-100" onclick="return confirm('Terima barang dan update stok?')">
                <i class="bi bi-check-lg me-1"></i>Terima Barang
              </button>
            </form>
            <form action="/purchase-orders/<%= order.id %>/status" method="POST">
              <input type="hidden" name="status" value="cancelled">
              <button type="submit" class="btn btn-outline-danger w-100" onclick="return confirm('Batalkan PO ini?')">
                <i class="bi bi-x-lg me-1"></i>Batalkan
              </button>
            </form>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>
</div>
