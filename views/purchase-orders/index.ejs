<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Purchase Orders</h4>
  <a href="/purchase-orders/create" class="btn btn-primary">
    <i class="bi bi-plus-lg me-1"></i>Buat PO
  </a>
</div>

<!-- Filter -->
<div class="card mb-4">
  <div class="card-body">
    <form action="/purchase-orders" method="GET" class="row g-2">
      <div class="col-md-4">
        <select name="status" class="form-select">
          <option value="" <%= !selectedStatus ? 'selected' : '' %>>Semua Status</option>
          <option value="draft" <%= selectedStatus === 'draft' ? 'selected' : '' %>>Draft</option>
          <option value="ordered" <%= selectedStatus === 'ordered' ? 'selected' : '' %>>Ordered</option>
          <option value="received" <%= selectedStatus === 'received' ? 'selected' : '' %>>Received</option>
          <option value="cancelled" <%= selectedStatus === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Filter</button>
      </div>
    </form>
  </div>
</div>

<!-- PO Table -->
<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>No. PO</th>
            <th>Tanggal</th>
            <th>Supplier</th>
            <th>Dibuat Oleh</th>
            <th class="text-end">Total</th>
            <th class="text-center">Status</th>
            <th class="text-center">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (orders.length === 0) { %>
            <tr>
              <td colspan="7" class="text-center text-muted py-4">Tidak ada Purchase Order</td>
            </tr>
          <% } else { %>
            <% orders.forEach(order => { %>
              <tr>
                <td>
                  <a href="/purchase-orders/<%= order.id %>" class="text-decoration-none fw-bold">
                    <%= order.po_number %>
                  </a>
                </td>
                <td><%= new Date(order.created_at).toLocaleDateString('id-ID') %></td>
                <td><%= order.supplier_name || '-' %></td>
                <td><%= order.user_name %></td>
                <td class="text-end">Rp <%= order.total.toLocaleString('id-ID') %></td>
                <td class="text-center">
                  <% if (order.status === 'draft') { %>
                    <span class="badge bg-secondary">Draft</span>
                  <% } else if (order.status === 'ordered') { %>
                    <span class="badge bg-primary">Ordered</span>
                  <% } else if (order.status === 'received') { %>
                    <span class="badge bg-success">Received</span>
                  <% } else { %>
                    <span class="badge bg-danger">Cancelled</span>
                  <% } %>
                </td>
                <td class="text-center">
                  <div class="btn-group btn-group-sm">
                    <a href="/purchase-orders/<%= order.id %>" class="btn btn-outline-primary" title="Detail">
                      <i class="bi bi-eye"></i>
                    </a>
                    <a href="/purchase-orders/<%= order.id %>/print" class="btn btn-outline-secondary" target="_blank" title="Print">
                      <i class="bi bi-printer"></i>
                    </a>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
