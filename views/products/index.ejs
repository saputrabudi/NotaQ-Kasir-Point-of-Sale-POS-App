<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0"><i class="bi bi-box-seam me-2"></i>Manajemen Produk</h4>
  <a href="/products/create" class="btn btn-primary">
    <i class="bi bi-plus-lg me-1"></i>Tambah Produk
  </a>
</div>

<!-- Filter -->
<div class="card mb-4">
  <div class="card-body">
    <form action="/products" method="GET" class="row g-2">
      <div class="col-md-6">
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-search"></i></span>
          <input type="text" class="form-control" name="search" placeholder="Cari nama atau barcode..." value="<%= search %>">
        </div>
      </div>
      <div class="col-md-4">
        <select name="category" class="form-select">
          <option value="">Semua Kategori</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>" <%= selectedCategory == cat.id ? 'selected' : '' %>><%= cat.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Filter</button>
      </div>
    </form>
  </div>
</div>

<!-- Products Table -->
<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Barcode</th>
            <th>Nama Produk</th>
            <th>Kategori</th>
            <th class="text-end">Harga Beli</th>
            <th class="text-end">Harga Jual</th>
            <th class="text-center">Stok</th>
            <th class="text-center">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (products.length === 0) { %>
            <tr>
              <td colspan="7" class="text-center text-muted py-4">Tidak ada produk ditemukan</td>
            </tr>
          <% } else { %>
            <% products.forEach(product => { %>
              <tr>
                <td><code><%= product.barcode || '-' %></code></td>
                <td><%= product.name %></td>
                <td><%= product.category_name || '-' %></td>
                <td class="text-end">Rp <%= product.buy_price.toLocaleString('id-ID') %></td>
                <td class="text-end">Rp <%= product.sell_price.toLocaleString('id-ID') %></td>
                <td class="text-center">
                  <% if (product.stock <= 0) { %>
                    <span class="badge bg-danger"><%= product.stock %></span>
                  <% } else if (product.stock <= product.min_stock) { %>
                    <span class="badge bg-warning text-dark"><%= product.stock %></span>
                  <% } else { %>
                    <span class="badge bg-success"><%= product.stock %></span>
                  <% } %>
                </td>
                <td class="text-center">
                  <div class="btn-group btn-group-sm">
                    <a href="/products/<%= product.id %>/edit" class="btn btn-outline-primary" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <a href="/stock/adjustment/<%= product.id %>" class="btn btn-outline-success" title="Sesuaikan Stok">
                      <i class="bi bi-boxes"></i>
                    </a>
                    <button type="button" class="btn btn-outline-danger" title="Hapus" onclick="confirmDelete(<%= product.id %>, '<%= product.name %>')">
                      <i class="bi bi-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="card-footer bg-white">
    <small class="text-muted">Total: <%= products.length %> produk</small>
  </div>
</div>

<!-- Delete Form (Hidden) -->
<form id="deleteForm" method="POST" style="display: none;">
  <input type="hidden" name="_method" value="DELETE">
</form>

<script>
function confirmDelete(id, name) {
  Swal.fire({
    title: 'Hapus Produk?',
    text: `Apakah Anda yakin ingin menghapus "${name}"?`,
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#dc3545',
    cancelButtonColor: '#6c757d',
    confirmButtonText: 'Ya, Hapus!',
    cancelButtonText: 'Batal'
  }).then((result) => {
    if (result.isConfirmed) {
      const form = document.getElementById('deleteForm');
      form.action = `/products/${id}?_method=DELETE`;
      form.submit();
    }
  });
}
</script>
