<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0"><i class="bi bi-clipboard-data me-2"></i>Laporan Stok</h4>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="card bg-primary text-white h-100">
      <div class="card-body text-center">
        <h6>Total Produk</h6>
        <h2><%= summary.total_products %></h2>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card bg-success text-white h-100">
      <div class="card-body text-center">
        <h6>Total Stok</h6>
        <h2><%= summary.total_stock %></h2>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card bg-warning text-dark h-100">
      <div class="card-body text-center">
        <h6>Stok Menipis</h6>
        <h2><%= summary.low_stock %></h2>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card bg-info text-white h-100">
      <div class="card-body text-center">
        <h6>Nilai Stok</h6>
        <h3>Rp <%= Math.round(summary.stock_value || 0).toLocaleString('id-ID') %></h3>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <!-- Stock by Category -->
  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header bg-white">
        <h6 class="mb-0">Stok per Kategori</h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Kategori</th>
                <th class="text-center">Produk</th>
                <th class="text-center">Stok</th>
                <th class="text-end">Nilai</th>
              </tr>
            </thead>
            <tbody>
              <% stockByCategory.forEach(row => { %>
                <tr>
                  <td><%= row.category_name %></td>
                  <td class="text-center"><%= row.product_count %></td>
                  <td class="text-center"><%= row.total_stock %></td>
                  <td class="text-end">Rp <%= Math.round(row.stock_value || 0).toLocaleString('id-ID') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Low Stock Products -->
  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Produk Stok Menipis</h6>
        <a href="/stock?filter=low" class="btn btn-sm btn-outline-primary">Lihat Semua</a>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive" style="max-height: 400px;">
          <table class="table table-hover mb-0">
            <thead class="table-light sticky-top">
              <tr>
                <th>Produk</th>
                <th class="text-center">Stok</th>
                <th class="text-center">Min</th>
                <th class="text-center">Status</th>
              </tr>
            </thead>
            <tbody>
              <% if (lowStockProducts.length === 0) { %>
                <tr>
                  <td colspan="4" class="text-center text-muted py-4">Tidak ada produk stok menipis</td>
                </tr>
              <% } else { %>
                <% lowStockProducts.forEach(product => { %>
                  <tr>
                    <td>
                      <%= product.name %>
                      <br><small class="text-muted"><%= product.category_name || '-' %></small>
                    </td>
                    <td class="text-center"><strong><%= product.stock %></strong></td>
                    <td class="text-center"><%= product.min_stock %></td>
                    <td class="text-center">
                      <% if (product.stock <= 0) { %>
                        <span class="badge bg-danger">Habis</span>
                      <% } else { %>
                        <span class="badge bg-warning text-dark">Menipis</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Recent Movements -->
<div class="card mt-4">
  <div class="card-header bg-white d-flex justify-content-between align-items-center">
    <h6 class="mb-0">Pergerakan Stok Terakhir</h6>
    <a href="/stock/history" class="btn btn-sm btn-outline-primary">Lihat Semua</a>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Tanggal</th>
            <th>Produk</th>
            <th>User</th>
            <th class="text-center">Perubahan</th>
            <th>Alasan</th>
          </tr>
        </thead>
        <tbody>
          <% if (recentMovements.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center text-muted py-4">Belum ada pergerakan stok</td>
            </tr>
          <% } else { %>
            <% recentMovements.forEach(mov => { %>
              <tr>
                <td><%= new Date(mov.created_at).toLocaleString('id-ID') %></td>
                <td><%= mov.product_name %></td>
                <td><%= mov.user_name %></td>
                <td class="text-center">
                  <span class="badge bg-<%= mov.adjustment > 0 ? 'success' : 'danger' %>">
                    <%= mov.adjustment > 0 ? '+' : '' %><%= mov.adjustment %>
                  </span>
                  <small class="text-muted">(<%= mov.qty_before %> → <%= mov.qty_after %>)</small>
                </td>
                <td><%= mov.reason || '-' %></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
