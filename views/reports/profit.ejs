<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0"><i class="bi bi-cash-stack me-2"></i>Laporan Keuntungan</h4>
</div>

<!-- Filter -->
<div class="card mb-4">
  <div class="card-body">
    <form action="/reports/profit" method="GET" class="row g-2">
      <div class="col-md-4">
        <input type="date" class="form-control" name="date_from" value="<%= dateFrom %>" placeholder="Dari tanggal">
      </div>
      <div class="col-md-4">
        <input type="date" class="form-control" name="date_to" value="<%= dateTo %>" placeholder="Sampai tanggal">
      </div>
      <div class="col-md-4">
        <button type="submit" class="btn btn-primary w-100">
          <i class="bi bi-filter me-1"></i>Filter
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card bg-primary text-white h-100">
      <div class="card-body text-center">
        <h6>Total Penjualan</h6>
        <h2>Rp <%= Math.round(summary.totalSales).toLocaleString('id-ID') %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card bg-danger text-white h-100">
      <div class="card-body text-center">
        <h6>Total Modal</h6>
        <h2>Rp <%= Math.round(summary.totalCost).toLocaleString('id-ID') %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card bg-success text-white h-100">
      <div class="card-body text-center">
        <h6>Total Keuntungan</h6>
        <h2>Rp <%= Math.round(summary.totalProfit).toLocaleString('id-ID') %></h2>
        <small>
          <% const margin = summary.totalCost > 0 ? ((summary.totalProfit / summary.totalCost) * 100).toFixed(1) : 0 %>
          Margin: <%= margin %>%
        </small>
      </div>
    </div>
  </div>
</div>

<!-- Profit Table -->
<div class="card">
  <div class="card-header bg-white">
    <h6 class="mb-0">Detail Keuntungan per Produk</h6>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Produk</th>
            <th>Barcode</th>
            <th class="text-center">Qty Terjual</th>
            <th class="text-end">Total Penjualan</th>
            <th class="text-end">Total Modal</th>
            <th class="text-end">Keuntungan</th>
            <th class="text-center">Margin</th>
          </tr>
        </thead>
        <tbody>
          <% if (profitData.length === 0) { %>
            <tr>
              <td colspan="7" class="text-center text-muted py-4">Tidak ada data</td>
            </tr>
          <% } else { %>
            <% profitData.forEach(row => { %>
              <tr>
                <td><%= row.name %></td>
                <td><code><%= row.barcode || '-' %></code></td>
                <td class="text-center"><%= row.qty_sold %></td>
                <td class="text-end">Rp <%= Math.round(row.total_sales).toLocaleString('id-ID') %></td>
                <td class="text-end">Rp <%= Math.round(row.total_cost).toLocaleString('id-ID') %></td>
                <td class="text-end">
                  <span class="<%= row.profit >= 0 ? 'text-success' : 'text-danger' %>">
                    Rp <%= Math.round(row.profit).toLocaleString('id-ID') %>
                  </span>
                </td>
                <td class="text-center">
                  <% const rowMargin = row.total_cost > 0 ? ((row.profit / row.total_cost) * 100).toFixed(1) : 0 %>
                  <span class="badge bg-<%= rowMargin >= 0 ? 'success' : 'danger' %>">
                    <%= rowMargin %>%
                  </span>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
